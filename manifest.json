{
  "manifest_version": 2,
  "name": "Mindwtr Quick Add",
  "version": "1.0.0",
  "description": "Add current page to Mindwtr inbox",

  "permissions": [
    "activeTab",
    "storage",
    "<all_urls>"
  ],

  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Add to Mindwtr"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },

  "icons": {
    "48": "icons/icon-48.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "mindwtr-quick-add@dlawrence",
      "strict_min_version": "57.0"
    }
  }
}
